<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    cocktail-highlight
    cocktail-highlight-{{ section.id }}
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  <div class="cocktail-highlight__inner">
    <div class="cocktail-highlight__text">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>

    {% if section.settings.featured_product %}
      {% assign product = section.settings.featured_product %}
      <div class="cocktail-highlight__product">
        <div class="cocktail-highlight__media">
          <img
            src="{{ product.featured_image | image_url: width: 600 }}"
            alt="{{ product.title }}"
            width="600"
            height="{{ 600 | divided_by: product.featured_image.aspect_ratio }}"
            loading="lazy"
          >
          <div class="cocktail-highlight__badge">
            {% render 'cocktail-badge', label: section.settings.badge_label %}
          </div>
        </div>
        <h3>{{ product.title }}</h3>
        <p>{{ product.price | money }}</p>
        <a href="{{ product.url }}">View cocktail</a>
      </div>
    {% endif %}
  </div>
</div>

<style>
  .cocktail-highlight-{{ section.id }} .cocktail-highlight__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }

  .cocktail-highlight-{{ section.id }} .cocktail-highlight__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    max-width: 700px;
  }

  .cocktail-highlight-{{ section.id }} .cocktail-highlight__text h2 {
    margin: 0;
  }

  .cocktail-highlight-{{ section.id }} .cocktail-highlight__text p {
    margin: 0;
  }

  .cocktail-highlight-{{ section.id }} .cocktail-highlight__product {
    max-width: 600px;
  }

  .cocktail-highlight-{{ section.id }} .cocktail-highlight__media {
    position: relative;
  }

  .cocktail-highlight-{{ section.id }} .cocktail-highlight__media img {
    max-width: 600px;
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px;
  }

  .cocktail-highlight-{{ section.id }} .cocktail-highlight__badge {
    position: absolute;
    top: 16px;
    left: 16px;
  }

  .cocktail-highlight-{{ section.id }} .cocktail-highlight__product h3,
  .cocktail-highlight-{{ section.id }} .cocktail-highlight__product p {
    margin: 12px 0 0;
  }
</style>

{% schema %}
{
  "name": "Cocktail Highlight",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Art of the Cocktail"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium ingredients. Timeless recipes. Unforgettable drinks."
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured product"
    },
    {
      "type": "text",
      "id": "badge_label",
      "label": "Badge label",
      "default": "Classic"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between text and product",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Cocktail Highlight"
    }
  ]
}
{% endschema %}
